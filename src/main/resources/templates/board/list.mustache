{{> layout/header}}

<div class="container mt-3">
    <div class="row">
        <div class="col-md-12">
            <h1>게시글 목록</h1>
            <hr>
            <table class="table table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>번호</th>
                        <th>제목</th>
                        <th>상세보기</th>
                    </tr>
                </thead>
                <tbody>
                    {{#models}}
                    <tr>
                        <td>{{id}}</td>
                        <td>{{title}}</td>
                        <td><a href="/board/{{id}}" class="btn btn-primary btn-sm">상세보기</a></td>
                    </tr>
                    {{/models}}
                </tbody>
            </table>

            <div class="mt-4 text-center">
                <p class="text-muted">현재 페이지: <strong>{{currentPage}}</strong> (주소창에 <code>?page=1</code> 등을 입력해 보세요!)</p>
            </div>
        </div>
    </div>
</div>

{{> layout/footer}}