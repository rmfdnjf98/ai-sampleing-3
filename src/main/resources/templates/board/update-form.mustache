{{> layout/header}}

<div class="container mt-3">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-warning text-dark">
                    <h3 class="card-title mb-0">게시글 수정</h3>
                </div>
                <div class="card-body p-4">
                    <form action="/board/{{model.id}}/update" method="post">
                        <div class="mb-4">
                            <label for="title" class="form-label fw-bold">제목</label>
                            <input type="text" class="form-control form-control-lg" id="title" name="title" 
                                   value="{{model.title}}" required>
                        </div>
                        <div class="mb-4">
                            <label for="content" class="form-label fw-bold">내용</label>
                            <textarea class="form-control" id="content" name="content" rows="10" 
                                      required>{{model.content}}</textarea>
                        </div>
                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a href="/board/{{model.id}}" class="btn btn-outline-secondary px-4 me-md-2">취소</a>
                            <button type="submit" class="btn btn-warning px-5">수정완료</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

{{> layout/footer}}
