{{> layout/header}}

<div class="container mt-3">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h3 class="card-title mb-0">새 게시글 작성</h3>
                </div>
                <div class="card-body p-4">
                    <form action="/board/save" method="post">
                        <div class="mb-4">
                            <label for="title" class="form-label fw-bold">제목</label>
                            <input type="text" class="form-control form-control-lg" id="title" name="title" 
                                   placeholder="제목을 입력하세요" required>
                        </div>
                        <div class="mb-4">
                            <label for="content" class="form-label fw-bold">내용</label>
                            <textarea class="form-control" id="content" name="content" rows="10" 
                                      placeholder="내용을 입력하세요" required></textarea>
                        </div>
                        <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                            <a href="/" class="btn btn-outline-secondary px-4 me-md-2">취소</a>
                            <button type="submit" class="btn btn-primary px-5">작성완료</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

{{> layout/footer}}
