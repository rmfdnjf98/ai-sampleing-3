{{> layout/header}}

<style>
    :root {
        --color-primary: #197fe6;
        --color-danger: #dc3545;
        --radius-base: 12px;
        --shadow-base: 0 4px 20px rgba(0,0,0,0.05);
        --font-family-base: 'Plus Jakarta Sans', 'Pretendard', sans-serif;
    }

    body {
        font-family: var(--font-family-base);
        background-color: #f8f9fa;
    }

    .update-card {
        border: none;
        border-radius: var(--radius-base);
        box-shadow: var(--shadow-base);
        overflow: hidden;
    }

    .update-card .card-header {
        background-color: #fff;
        border-bottom: 1px solid #eee;
        padding: 1.5rem;
    }

    .update-card .card-body {
        padding: 2rem;
    }

    .form-label {
        font-weight: 500;
        color: #495057;
    }

    .form-control {
        border-radius: 8px;
        padding: 0.6rem 1rem;
        border: 1px solid #dee2e6;
    }

    .form-control[readonly] {
        background-color: #e9ecef;
    }

    .btn-primary {
        background-color: var(--color-primary);
        border: none;
        border-radius: 8px;
        padding: 0.7rem;
        font-weight: 600;
    }

    .btn-danger {
        border-radius: 8px;
        padding: 0.7rem;
        font-weight: 600;
    }

    .section-title {
        font-size: 1.1rem;
        font-weight: 700;
        margin-bottom: 1.5rem;
        color: #212529;
        display: flex;
        align-items: center;
    }

    .section-title i {
        margin-right: 8px;
        color: var(--color-primary);
    }
</style>

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card update-card">
                <div class="card-header text-center">
                    <h3 class="mb-0">회원 정보 수정</h3>
                    <p class="text-muted mt-2">소중한 정보를 안전하게 변경하세요</p>
                </div>
                <div class="card-body">
                    <form action="/user/update" method="post">
                        <!-- 기본 정보 섹션 -->
                        <div class="section-title">
                            <i class="fa-solid fa-user-gear"></i> 기본 정보
                        </div>
                        
                        <div class="mb-4">
                            <label for="username" class="form-label">아이디</label>
                            <input type="text" class="form-control" id="username" name="username" 
                                   value="{{user.username}}" readonly>
                            <div class="form-text mt-1 text-muted">아이디는 변경할 수 없습니다.</div>
                        </div>

                        <div class="mb-4">
                            <label for="password" class="form-label">새 비밀번호</label>
                            <input type="password" class="form-control" id="password" name="password" 
                                   placeholder="변경할 비밀번호를 입력하세요" required>
                        </div>

                        <div class="mb-4">
                            <label for="email" class="form-label">이메일</label>
                            <input type="email" class="form-control" id="email" name="email" 
                                   value="{{user.email}}" required>
                        </div>

                        <hr class="my-4">

                        <!-- 주소 정보 섹션 -->
                        <div class="section-title">
                            <i class="fa-solid fa-location-dot"></i> 주소 설정 (선택사항)
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label">배송지 정보</label>
                            <div class="input-group mb-2">
                                <input type="text" class="form-control" id="postcode" name="postcode" 
                                       placeholder="우편번호" value="{{user.postcode}}" readonly>
                                <button class="btn btn-outline-secondary" type="button" onclick="execDaumPostcode()">우편번호 찾기</button>
                            </div>
                            <input type="text" class="form-control mb-2" id="address" name="address" 
                                   placeholder="주소" value="{{user.address}}" readonly>
                            <div class="row g-2">
                                <div class="col-6">
                                    <input type="text" class="form-control" id="detailAddress" name="detailAddress" 
                                           placeholder="상세주소" value="{{user.detailAddress}}">
                                </div>
                                <div class="col-6">
                                    <input type="text" class="form-control" id="extraAddress" name="extraAddress" 
                                           placeholder="참고항목" value="{{user.extraAddress}}" readonly>
                                </div>
                            </div>
                        </div>

                        <div class="d-grid mt-5">
                            <button class="btn btn-primary" type="submit">정보 수정하기</button>
                        </div>
                    </form>

                    <hr class="my-5">

                    <!-- 위험 구역 (탈퇴) -->
                    <div class="p-3 bg-light border rounded-3 mt-4">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="mb-1 fw-bold text-danger">회원 탈퇴</h6>
                                <p class="text-muted small mb-0">탈퇴 시 작성한 게시글과 댓글이 모두 삭제되며 복구할 수 없습니다.</p>
                            </div>
                            <form action="/user/withdraw" method="post" onsubmit="return confirmWithdraw()">
                                <button class="btn btn-danger btn-sm" type="submit">계정 삭제</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- 다음 우편번호 서비스 스크립트 -->
<script src="//t1.daumcdn.net/mapjsapi/bundle/postcode/prod/postcode.v2.js"></script>
<script>
    function confirmWithdraw() {
        return confirm("정말 탈퇴하시겠습니까? 작성한 모든 글과 댓글이 삭제되며, 이 작업은 되돌릴 수 없습니다.");
    }

    function execDaumPostcode() {
        new daum.Postcode({
            oncomplete: function(data) {
                var addr = '';
                var extraAddr = '';

                if (data.userSelectedType === 'R') {
                    addr = data.roadAddress;
                } else {
                    addr = data.jibunAddress;
                }

                if(data.userSelectedType === 'R'){
                    if(data.bname !== '' && /[동|로|가]$/g.test(data.bname)){
                        extraAddr += data.bname;
                    }
                    if(data.buildingName !== '' && data.apartment === 'Y'){
                        extraAddr += (extraAddr !== '' ? ', ' + data.buildingName : data.buildingName);
                    }
                    if(extraAddr !== ''){
                        extraAddr = ' (' + extraAddr + ')';
                    }
                    document.getElementById("extraAddress").value = extraAddr;
                } else {
                    document.getElementById("extraAddress").value = '';
                }

                document.getElementById('postcode').value = data.zonecode;
                document.getElementById("address").value = addr;
                document.getElementById("detailAddress").focus();
            }
        }).open();
    }
</script>

{{> layout/footer}}
